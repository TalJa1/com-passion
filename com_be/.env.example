# Neon Postgres connection string (libpq format; the app converts it for asyncpg)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
# Secret used to sign JWT access tokens — change in production
JWT_SECRET=change-me
# OAuth 2.0 Client ID from Google Cloud Console (same one the frontend uses)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
